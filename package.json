{
  "name": "matchbook",
  "private": false,
  "version": "2.0.1",
  "description": "Matchbook: offline-first FRC scouting and sync platform",
  "author": "Rishan Reddy",
  "license": "MIT",
  "homepage": "https://github.com/rishanreddy/matchbook",
  "repository": {
    "type": "git",
    "url": "https://github.com/rishanreddy/matchbook.git"
  },
  "bugs": {
    "url": "https://github.com/rishanreddy/matchbook/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "electron:dev": "pnpm dev",
    "build": "pnpm typecheck && electron-vite build",
    "electron:build": "pnpm build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:win": "pnpm build && electron-builder --win --publish never",
    "build:mac": "pnpm build && electron-builder --mac --publish never",
    "build:linux": "pnpm build && electron-builder --linux --publish never",
    "electron:dist": "pnpm build:unpack",
    "electron:dist:win": "pnpm build:win",
    "electron:dist:mac": "pnpm build:mac",
    "electron:dist:linux": "pnpm build:linux",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "verify:production": "pnpm typecheck && pnpm lint && pnpm build",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "@mantine/core": "^8.3.18",
    "@mantine/form": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@mantine/notifications": "^8.3.18",
    "@tabler/icons-react": "^3.41.0",
    "@tanstack/react-hotkeys": "^0.9.1",
    "axios": "^1.14.0",
    "dexie": "^4.4.1",
    "electron-updater": "^6.6.2",
    "html5-qrcode": "^2.3.8",
    "lz-string": "^1.5.0",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "qrcode.react": "^4.2.0",
    "querystring-es3": "^0.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "rxdb": "^16.21.1",
    "rxjs": "^7.8.2",
    "survey-core": "^2.5.17",
    "survey-creator-core": "^2.5.17",
    "survey-creator-react": "^2.5.17",
    "survey-react-ui": "^2.5.17",
    "tba-api-v3client": "^3.3.1",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^17.4.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "electron",
      "electron-winstaller",
      "esbuild",
      "protobufjs",
      "rxdb"
    ]
  }
}
